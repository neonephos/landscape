[{"category":"NeoNephos Foundation Projects","homepage_url":"https://github.com/cobaltcore-dev","id":"neonephos-foundation-projects--all--cobaltcore","logo_url":"http://landscape.neonephos.org/logos/fe4144f497cf51adf0f07e48ce2a898ec8066d2d383cf6d7413b16ffad430455.svg","name":"CobaltCore","subcategory":"All","accepted_at":"2025-11-18","annotations":{"project_org":"https://github.com/cobaltcore-dev"},"crunchbase_url":"https://www.crunchbase.com/organization/neonephos","description":"The mission of the Project is to provide a reimagined, opinionated, and Kubernetes enabled OpenStack distribution, fully embedded with other cloud components.","devstats_url":"https://insights.linuxfoundation.org/project/cobaltcore","lfx_slug":"cobaltcore","oss":true,"other_links":[{"name":"Calendar","url":"https://zoom-lfx.platform.linuxfoundation.org/meetings/cobaltcore"},{"name":"iCal","url":"https://webcal.prod.itx.linuxfoundation.org/lfx/lf66V8CCBTijsFZ7AI"},{"name":"Charter","url":"https://lfx-cdn-prod.s3.us-east-1.amazonaws.com/project-artifacts/cobaltcore/cobaltcore_Charter.pdf?v=1763511319012"}],"repositories":[{"url":"https://github.com/cobaltcore-dev/cortex","primary":true},{"url":"https://github.com/cobaltcore-dev/aurora-dashboard","primary":false},{"url":"https://github.com/cobaltcore-dev/openstack-nix","primary":false},{"url":"https://github.com/cobaltcore-dev/kvm-node-agent","primary":false},{"url":"https://github.com/cobaltcore-dev/openstack-hypervisor-operator","primary":false},{"url":"https://github.com/cobaltcore-dev/docs","primary":false}]},{"category":"NeoNephos Foundation Projects","homepage_url":"https://gardener.cloud/","id":"neonephos-foundation-projects--all--gardener","logo_url":"http://landscape.neonephos.org/logos/b5a140108dbd63acd1a353d0ec80cd16ef29fcc2a44f004684944f67a0773054.svg","name":"Gardener","subcategory":"All","accepted_at":"2025-11-18","annotations":{"project_org":"https://github.com/gardener"},"crunchbase_url":"https://www.crunchbase.com/organization/neonephos","description":"The mission of the Project is to provide homogeneous Kubernetes clusters at scale on any infrastructure using hosted control planes.","devstats_url":"https://insights.linuxfoundation.org/project/gardener","lfx_slug":"gardener","oss":true,"other_links":[{"name":"Calendar","url":"https://zoom-lfx.platform.linuxfoundation.org/meetings/gardener"},{"name":"iCal","url":"https://webcal.prod.itx.linuxfoundation.org/lfx/lf6ewSmFRM2jaDYlmB"},{"name":"Charter","url":"https://lfx-cdn-prod.s3.us-east-1.amazonaws.com/project-artifacts/gardener/gardener_Charter.pdf?v=1763510989994"}],"repositories":[{"url":"https://github.com/gardener/gardener","primary":true},{"url":"https://github.com/gardener/machine-controller-manager","primary":false},{"url":"https://github.com/gardener/etcd-druid","primary":false},{"url":"https://github.com/gardener/etcd-backup-restore","primary":false},{"url":"https://github.com/gardener/dashboard","primary":false},{"url":"https://github.com/gardener/autoscaler","primary":false}]},{"category":"NeoNephos Foundation Projects","homepage_url":"https://cloudoperators.github.io/greenhouse/","id":"neonephos-foundation-projects--all--greenhouse","logo_url":"http://landscape.neonephos.org/logos/547d8c4acc8b971d8f1c8864476f92e349ba5372599355312d583b848de2246e.svg","name":"Greenhouse","subcategory":"All","accepted_at":"2025-04-06","annotations":{"project_org":"https://github.com/cloudoperators"},"crunchbase_url":"https://www.crunchbase.com/organization/neonephos","description":"Greenhouse is a comprehensive platform designed to address the challenges of operating large-scale cloud infrastructures. It offers a holistic dashboard and API to manage various operational aspects efficiently and transparently. Moreover, it enables operations of a globally distributed cloud infrastructure in compliance with industry standards. The platform addresses common operational challenges such as the complexity of tools, fragmentation of configuration, visibility and permission management. Several plugins extend the core platform, providing cloud-native observability, security & compliance tooling and more. These plugins come with sane default configurations and include all necessary components for application-specific needs such as production-proven alerts, playbooks, metric visualization dashboards.","devstats_url":"https://insights.linuxfoundation.org/project/greenhouse","lfx_slug":"greenhouse","oss":true,"other_links":[{"name":"Calendar","url":"https://zoom-lfx.platform.linuxfoundation.org/meetings/greenhouse"},{"name":"iCal","url":"https://webcal.prod.itx.linuxfoundation.org/lfx/lfOR02rCuEhDDjajJL"},{"name":"Charter","url":"https://lfx-cdn-prod.s3.us-east-1.amazonaws.com/project-artifacts/greenhouse/greenhouse_Charter.pdf?v=1761933677450"}],"repositories":[{"url":"https://github.com/cloudoperators/greenhouse","primary":true},{"url":"https://github.com/cloudoperators/greenhouse-extensions","primary":false},{"url":"https://github.com/cloudoperators/juno","primary":false},{"url":"https://github.com/cloudoperators/heureka","primary":false},{"url":"https://github.com/cloudoperators/steering","primary":false}]},{"category":"NeoNephos Foundation Projects","homepage_url":"https://ironcore-dev.github.io/ironcore/","id":"neonephos-foundation-projects--all--ironcore","logo_url":"http://landscape.neonephos.org/logos/0534dde3e4b31375dda2e47f002b9388c2c0a1377f5f7bb6219b720a47b7d549.svg","name":"IronCore","subcategory":"All","accepted_at":"2025-08-29","annotations":{"project_org":"https://github.com/ironcore-dev"},"crunchbase_url":"https://www.crunchbase.com/organization/neonephos","description":"IronCore provides the new reference for compounded software layers for inventorying, managing, and maintaining Baremetal using Kubernetes’ cloud-native principles. Kubernetes, originally designed to manage and orchestrate containerized applications and microservices, has significantly expanded its reach through its inherent API extensibility, allowing it to be adapted to a wide range of use cases entirely outside the realm of containers. IronCore takes a modern spin with Kubernetes, offering a single interface for managing resources orchestrated across regions, data centers, and availability zones. All assembled with the identical blueprint, thereby offering unmatched flexibility, scalability, and ease of use. Unlike traditional infrastructure solutions, IronCore delivers a much sought, fresh, next generation approach. As a default, Ceph is modularly provided as a cloud-natively automated, vendor-neutral storage backend for block, shared, and object storage. Furthermore, a disruptive network fabric based on CLOS Topology is included. The software defined network data plane materializes through routed layer 3 only, using an IPv6 overlay, and is grounded on the robust, standard experience of the established internet architecture and technology.","devstats_url":"https://insights.linuxfoundation.org/project/ironcore","lfx_slug":"ironcore","oss":true,"other_links":[{"name":"Calendar","url":"https://zoom-lfx.platform.linuxfoundation.org/meetings/ironcore"},{"name":"iCal","url":"https://webcal.prod.itx.linuxfoundation.org/lfx/lfdpQVHdB0pX7liH2V"},{"name":"Charter","url":"https://lfx-cdn-prod.s3.us-east-1.amazonaws.com/project-artifacts/ironcore/ironcore_Charter.pdf?v=1761932939494"}],"repositories":[{"url":"https://github.com/ironcore-dev/ironcore","primary":true},{"url":"https://github.com/ironcore-dev/ironcore-net","primary":false},{"url":"https://github.com/ironcore-dev/ceph-provider","primary":false},{"url":"https://github.com/ironcore-dev/libvirt-provider","primary":false},{"url":"https://github.com/ironcore-dev/dpservice","primary":false},{"url":"https://github.com/ironcore-dev/metal-operator","primary":false}]},{"category":"NeoNephos Foundation Projects","homepage_url":"https://github.com/telekom/NeoNephos-Katalis","id":"neonephos-foundation-projects--all--katalis","logo_url":"http://landscape.neonephos.org/logos/020ae2ab62f4b8c55ac2fc08a7dd82a194b5e27f53ec38c6fdaae9d6bfad7451.svg","name":"Katalis","subcategory":"All","accepted_at":"2026-03-30","crunchbase_url":"https://www.crunchbase.com/organization/neonephos","description":"develop solutions to bridge Telco and Cloud Provider APIs utilizing Kubernetes to drive orchestration and federation principles","devstats_url":"https://insights.linuxfoundation.org/project/katalis","lfx_slug":"katalis","oss":true,"other_links":[{"name":"Calendar","url":"https://zoom-lfx.platform.linuxfoundation.org/meetings/katalis"},{"name":"iCal","url":"https://webcal.prod.itx.linuxfoundation.org/lfx/lfT8I2Rgyq7mrXO2QU"},{"name":"Charter","url":"https://lfx-cdn-prod.s3.us-east-1.amazonaws.com/project-artifacts/katalis/katalis_Charter.pdf?v=1774985434219"}],"repositories":[{"url":"https://github.com/telekom/NeoNephos-Katalis","primary":true}]},{"category":"NeoNephos Foundation Projects","homepage_url":"https://luigi-project.io/","id":"neonephos-foundation-projects--all--luigi","logo_url":"http://landscape.neonephos.org/logos/0f61745b9a51e35460378b8404d46f46b6708e77059e2e903132949f25339ae6.svg","name":"Luigi","subcategory":"All","accepted_at":"2025-12-02","annotations":{"project_org":"https://github.com/luigi-project"},"crunchbase_url":"https://www.crunchbase.com/organization/neonephos","description":"Luigi was first introduced as an open source project in 2018, together with kyma.\nKey features include:\nModular architecture: Breaks down monolithic apps into smaller, manageable UI modules.\nExtensibility: Easily integrates external UI components.\nScalability: Supports distributed development across multiple teams.\nTechnology agnostic: Works with any frontend technology, avoiding vendor lock-in.","devstats_url":"https://insights.linuxfoundation.org/project/luigi","lfx_slug":"luigi","oss":true,"other_links":[{"name":"Calendar","url":"https://zoom-lfx.platform.linuxfoundation.org/meetings/luigi"},{"name":"iCal","url":"https://webcal.p