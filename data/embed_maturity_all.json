{"classification":{"maturity":[{"name":"growth","normalized_name":"growth"},{"name":"impact","normalized_name":"impact"},{"name":"incubation","normalized_name":"incubation"}]},"foundation":"NeoNephos Foundation","items":[{"category":"Application Layer","id":"application-layer--federation-domain--luigi","name":"Luigi","logo":"logos/fb0cfbfac2a10f30e6352485e61a900874a4dcf3265a53d00f6023d2b2389ef3.svg","subcategory":"Federation Domain","website":"https://github.com/luigi-project/","maturity":"incubation","primary_repository_url":"https://github.com/luigi-project/luigi"},{"category":"Application Layer","id":"application-layer--federation-domain--open-micro-frontend-platform","name":"Open Micro Frontend Platform","logo":"logos/aaffa50d76ce247e8f7e7b148207900facede15e5d6e0f5f6fd78a8673cbe21d.svg","subcategory":"Federation Domain","website":"https://openmfp.org/","maturity":"incubation","primary_repository_url":"https://github.com/openmfp"},{"category":"Application Layer","id":"application-layer--security-and-compliance-domain--open-component-model","name":"Open Component Model","logo":"logos/f7ff5f5c0df835cfd301a2863ddeaef86b87b1da1ffcf8c38ff6ba8f598901d3.svg","subcategory":"Security and Compliance Domain","website":"https://ocm.software/","maturity":"incubation","primary_repository_url":"https://github.com/open-component-model/"},{"category":"Cloud Edge Platform Layer","id":"cloud-edge-platform-layer--federation-domain--platform-mesh","name":"Platform Mesh","logo":"logos/e8050c5d0ac5e46a95d131b5357fa56ef1ca17db8638dcf49ca1c635de3749c9.svg","subcategory":"Federation Domain","website":"https://platform-mesh.io/","description":"The Platform Mesh defines an environment that allows service providers to offer services of any kind and service consumers to discover those services, order capabilities, and control their lifecycle.\n\n\"Platform Mesh\" enables developers (consumers) to select and utilize the needed and preferred services from various service marketplaces.\n\nIt does not make any assumptions about these services or the marketplaces, nor does it mandate the use of any specific services. Instead, it offers a mesh and the essential contracts that allows service providers to offer their services freely and enables service consumers to discover, order, and use these services.\n\nThis framework aims to transcend the traditional layered approach of strictly separating IaaS, PaaS, and SaaS in past infrastructures. Both higher-level and lower-level services are provided and managed through the same mechanism.\n","maturity":"incubation","primary_repository_url":"https://github.com/platform-mesh/helm-charts"},{"category":"Data Layer","id":"data-layer--federation-domain--open-resource-discovery","name":"Open Resource Discovery","logo":"logos/e9713c0a3b41a18b3224da7719a312c4899c76ef9d823897851633e07f24573b.svg","subcategory":"Federation Domain","website":"https://open-resource-discovery.github.io/specification/","maturity":"incubation","primary_repository_url":"https://github.com/open-resource-discovery"},{"category":"Physical Cloud Edge Resources Layer","id":"physical-cloud-edge-resources-layer--federation-domain--garden-linux","name":"Garden Linux","logo":"logos/5eaaf09b23128970b9823a3c91a038116a2ae0ae0d3b1a83a14a00c6ebc10a60.svg","subcategory":"Federation Domain","website":"https://gardenlinux.org/","maturity":"growth","primary_repository_url":"https://github.com/gardenlinux"},{"category":"Service Orchestration Layer","id":"service-orchestration-layer--federation-domain--gardener","name":"Gardener","logo":"logos/a8059752ee1f45867b80aa1758851dbf7fe1bb495a8e34447d557b1af52b341a.svg","subcategory":"Federation Domain","website":"https://gardener.cloud","maturity":"impact","primary_repository_url":"https://github.com/gardener/gardener"},{"category":"Service Orchestration Layer","id":"service-orchestration-layer--management-domain--greenhouse","name":"Greenhouse","logo":"logos/74d80e340c82500a4981d73a1a86008e8f2c6ff6cad43de9bfdeff125df52aa7.s